# ===========================================
# CodeHub – Environment variables
# ===========================================
# Copy to .env and fill in values. Do not commit .env.

# ---------- Backend (Render / local server) ----------
PORT=5000
MONGODB_URI_CODEHUB=mongodb+srv://user:pass@cluster.mongodb.net/CodeHub
# Quiz DB (e.g. QuizAppCluster). Use database IIT_project with collections: questions, quizscores, quizusersettings
QUIZ_MONGODB_URI=mongodb+srv://user:pass@quizappcluster.mongodb.net
QUIZ_DB_NAME=IIT_project
# Frontend origin for CORS (e.g. Vercel URL)
FRONTEND_URL=https://codehub-peach.vercel.app

# ---------- Frontend (Vercel / local dev) ----------
# In Vercel: add as Environment Variable (VITE_API_URL).
# In local dev: create .env in Codehub/ with:
# Backend origin only (no path). Same URL is used for API and WebSocket.
# Local:   VITE_API_URL=http://localhost:5000
# Production: VITE_API_URL=https://codehub-dogj.onrender.com
